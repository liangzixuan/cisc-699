# SafeExec environment template
#
# Copy to `.env` only if you need local overrides. The current prototype uses
# no secrets and no external API credentials.

# Development-only backend for local smoke tests. Use `docker` or `gvisor` only
# on a Linux host with Docker and, for gVisor, runsc installed.
SAFEEXEC_DEFAULT_BACKEND=local

# Local API bind settings used by `make api`.
SAFEEXEC_API_HOST=127.0.0.1
SAFEEXEC_API_PORT=8080

# Container image used by the Docker/gVisor backend.
SAFEEXEC_CONTAINER_IMAGE=python:3.11-slim

# Optional benchmark/reproducibility knobs.
SAFEEXEC_REPEAT=3
SAFEEXEC_OUTPUT_DIR=docs/10-hard-stop-5/evidence
